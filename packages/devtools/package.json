{
  "name": "@aicorg/devtools",
  "version": "0.1.0-alpha.1",
  "type": "module",
  "description": "Browser devtools bridge, overlay, and inspector helpers for AIC instrumented apps.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/VPAI-Grok/AIC.git"
  },
  "homepage": "https://github.com/VPAI-Grok/AIC",
  "bugs": {
    "url": "https://github.com/VPAI-Grok/AIC/issues"
  },
  "keywords": [
    "aic",
    "agents",
    "devtools",
    "react",
    "browser-extension"
  ],
  "main": "./dist/devtools/src/index.js",
  "types": "./dist/devtools/src/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/devtools/src/index.d.ts",
      "import": "./dist/devtools/src/index.js",
      "default": "./dist/devtools/src/index.js"
    },
    "./client": {
      "types": "./dist/devtools/src/client.d.ts",
      "import": "./dist/devtools/src/client.js",
      "default": "./dist/devtools/src/client.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/sync-extension-assets.mjs",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@aicorg/runtime": "workspace:*",
    "@aicorg/sdk-react": "workspace:*",
    "@aicorg/spec": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
