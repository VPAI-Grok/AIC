{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "incremental": true,
    "paths": {
      "@aicorg/spec": [
        "../../packages/spec/dist/index.js"
      ],
      "@aicorg/runtime": [
        "../../packages/runtime/dist/runtime/src/index.js"
      ],
      "@aicorg/sdk-react": [
        "../../packages/sdk-react/dist/sdk-react/src/index.js"
      ],
      "@aicorg/sdk-react/client": [
        "../../packages/sdk-react/dist/sdk-react/src/client.js"
      ],
      "@aicorg/devtools": [
        "../../packages/devtools/dist/devtools/src/index.js"
      ],
      "@aicorg/devtools/client": [
        "../../packages/devtools/dist/devtools/src/client.js"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "noEmit": true,
    "jsx": "preserve"
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.mjs",
    "app/**/*.ts",
    "app/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
